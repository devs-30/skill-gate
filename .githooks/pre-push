#!/usr/bin/env bash
set -euo pipefail

# Guard against the recursive tag push this hook triggers below.
if [[ "${_AUTO_VERSION_PUSH:-}" == "1" ]]; then
  exit 0
fi

remote="$1"

# Versioning is done by `make version-bump`, which writes the new version into
# the manifests, commits it, and tags that commit. This hook does NOT create
# tags - it only makes sure existing version tags travel to the remote
# alongside the commits being pushed.
current_branch=$(git branch --show-current 2>/dev/null || echo "")
if [[ "$current_branch" != "main" ]]; then
  echo "Not on main - skipping tag sync."
  exit 0
fi

echo "=== Pre-push: syncing version tags ==="
_AUTO_VERSION_PUSH=1 git push --tags "$remote" >/dev/null 2>&1 || true
echo "=== Pre-push: OK ==="
